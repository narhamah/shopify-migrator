# Source store (the store you're migrating FROM)
SOURCE_SHOP_URL=your-source-store.myshopify.com
SOURCE_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Destination store (the store you're migrating TO)
DEST_SHOP_URL=your-dest-store.myshopify.com
DEST_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Magento (optional — for importing prices, product names, images)
MAGENTO_SITE_URL=https://taraformula.com
MAGENTO_STORE_CODE=us-en

OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
